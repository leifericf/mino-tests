;; mino-tests -- adversarial / E2E / soak battery for mino.
;; Pairs with the unit-test suite in the main mino repo.
;;
;; The mino submodule under mino/ is the runtime under test. Build
;; with `cd mino && make`, then run from this dir:
;;
;;   ./mino/mino task adv-test
;;   ./mino/mino task adv-test-soak
;;   ./mino/mino task adv-test-coverage      ; clang-only
;;   ./mino/mino task adv-test-sanitizers    ; ASan + UBSan + TSan
;;
;; MINO_BIN env overrides the binary used by the runner.

{:paths ["lib"]
 :tasks
 {adv-test          {:doc  "Smoke battery: fixed seed=0, under 30s, CI uses this"
                     :task mino-tests.tasks/adv-test}
  adv-test-soak     {:doc  "Full soak: random seed, several minutes, nightly CI"
                     :task mino-tests.tasks/adv-test-soak}
  diff-test         {:doc  "Differential probes only (smoke): random + targeted + JIT, ~1s"
                     :task mino-tests.tasks/diff-test}
  diff-test-soak    {:doc  "Differential probes (soak): 1000 random + 200/category, random seed"
                     :task mino-tests.tasks/diff-test-soak}
  adv-test-coverage {:doc  "Clang-only llvm-cov pass; writes tests/adv/coverage/report.html"
                     :task mino-tests.tasks/adv-test-coverage}
  adv-test-sanitizers {:doc "Triple sanitizer pass: ASan + UBSan + TSan"
                       :task mino-tests.tasks/adv-test-sanitizers}
  build-cov         {:doc  "Build mino_cov instrumented binary"
                     :task mino-tests.tasks/build-cov}
  bump-mino         {:doc  "Move mino submodule to a tag and stage the pin"
                     :task mino-tests.tasks/bump-mino}
  ci-matrix         {:doc  "Run release-gate inside Linux Docker images (dev host only)"
                     :task mino-tests.tasks/ci-matrix}
  test-migrated     {:doc  "Run the tests migrated out of mino's tests/ (sub-second per test)"
                     :task mino-tests.tasks/test-migrated}
  test-fault-inject {:doc  "Fault injection (simulated OOM) tests (moved from mino in v0.253.1)"
                     :task mino-tests.tasks/test-fault-inject}
  test-gc-stress    {:doc  "GC stability under MINO_GC_STRESS=1 (moved from mino in v0.253.1)"
                     :task mino-tests.tasks/test-gc-stress}
  gc-fuzz           {:doc  "Run mino tests/run.clj at 4 nursery sizes (64K/256K/1M/4M)"
                     :task mino-tests.tasks/gc-fuzz}
  gc-stress-subset  {:doc  "MINO_GC_STRESS=1 on mino's transient_test + gc_test only"
                     :task mino-tests.tasks/gc-stress-subset}
  gc-verify         {:doc  "MINO_GC_VERIFY=1 on mino tests/run.clj (allowed-to-fail)"
                     :task mino-tests.tasks/gc-verify}
  asan-per-file     {:doc  "One ASan subprocess per mino test file -- defeats full-suite Heisenbugs"
                     :task mino-tests.tasks/asan-per-file}}}
